    "# ─── 4.3  Export / Import knowledge base snapshot ─────────────────────────\n",
    "\n",
    "import json\n",
    "\n",
    "EXPORT_PATH = f'{BASE_PATH}/kb_export.json'\n",
    "\n",
    "def export_knowledge_base():\n",
    "    \"\"\"Export BM25 docs + processed log to a single JSON file.\"\"\"\n",
    "    snapshot = {\n",
    "        'bm25_docs':       load_bm25_docs(),\n",
    "        'processed_files': load_processed_log()\n",
    "    }\n",
    "    with open(EXPORT_PATH, 'w') as f:\n",
    "        json.dump(snapshot, f, indent=2, ensure_ascii=False)\n",
    "    size_kb = os.path.getsize(EXPORT_PATH) / 1024\n",
    "    print(f'✅ Knowledge base exported to {EXPORT_PATH}  ({size_kb:.1f} KB)')\n",
    "\n",
    "\n",
    "def import_knowledge_base(path: str = EXPORT_PATH):\n",
    "    \"\"\"Restore BM25 docs + processed log from a JSON snapshot.\"\"\"\n",
    "    global hybrid_retriever\n",
    "    with open(path, 'r') as f:\n",
    "        snapshot = json.load(f)\n",
    "    save_bm25_docs(snapshot['bm25_docs'])\n",
    "    save_processed_log(snapshot['processed_files'])\n",
    "    hybrid_retriever = build_hybrid_retriever([], embedding_model)  # Reload with no new docs\n",
    "    print(f'✅ Knowledge base imported from {path}')\n",
    "    print(f'   Chunks: {len(snapshot[\"bm25_docs\"])}, Files: {len(snapshot[\"processed_files\"])}')\n",
    "\n",
    "\n",
    "# Uncomment to use:\n",
    "# export_knowledge_base()\n",
    "# import_knowledge_base()\n",
    "\n",
    "print('✅ Export/Import helpers defined.')"
   ]
