    "# ─── 4.2  Add a text document manually (no image required) ────────────────\n",
    "# Useful for adding structured data directly (FAQs, schedules, etc.)\n",
    "\n",
    "from langchain_core.documents import Document\n",
    "\n",
    "def add_text_document(title: str, content: str, date: str = 'N/A', ref: str = 'MANUAL'):\n",
    "    \"\"\"\n",
    "    Add any plain-text document to the RAG knowledge base.\n",
    "    \"\"\"\n",
    "    global hybrid_retriever\n",
    "\n",
    "    text_splitter = RecursiveCharacterTextSplitter(\n",
    "        chunk_size=1500,\n",
    "        chunk_overlap=250,\n",
    "        separators=['\\n\\n', '\\n', '.', ' ', '']\n",
    "    )\n",
    "    chunks = text_splitter.split_text(content)\n",
    "\n",
    "    header = f'Notice Reference: {ref}, Date: {date}, Subject: {title}.\\nContent: '\n",
    "    metadata = {'reference_number': ref, 'date_issued': date, 'subject': title, 'issuing_authority': 'Manual Entry'}\n",
    "\n",
    "    docs = [Document(page_content=header + chunk, metadata=metadata) for chunk in chunks]\n",
    "\n",
    "    hybrid_retriever = build_hybrid_retriever(docs, embedding_model)\n",
    "    print(f'✅ Added \"{title}\" with {len(docs)} chunk(s).')\n",
    "\n",
    "\n",
    "# Example — uncomment to use:\n",
    "# add_text_document(\n",
    "#     title='E-Kalyan Scholarship 2026',\n",
    "#     content='Students from SC/ST/OBC categories must apply at ekalyan.cgg.gov.in before March 31, 2026.',\n",
    "#     date='2026-02-01',\n",
    "#     ref='EKalyan-2026'\n",
    "# )\n",
    "\n",
    "print('✅ add_text_document() helper defined.')"
   ]
