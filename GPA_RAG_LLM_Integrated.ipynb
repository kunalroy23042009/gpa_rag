   "id": "cell-gemini-client",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── 2.1  Initialise Gemini Client ────────────────────────────────────────\n",
    "from PIL import Image\n",
    "from google import genai\n",
    "from google.genai import types\n",
    "\n",
    "client = genai.Client()\n",
    "print('✅ Gemini client ready.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-pydantic-schema",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── 2.2  Pydantic schema for structured VLM extraction ───────────────────\n",
    "from pydantic import BaseModel, Field\n",
    "from typing import List, Optional\n",
    "\n",
    "\n",
    "class SignatoryEntity(BaseModel):\n",
    "    name_or_designation: str = Field(description=\"Official designation like 'प्राचार्य'\")\n",
    "    organization: Optional[str] = Field(description='Institution name if mentioned')\n",
    "    date_signed: Optional[str] = Field(description='Date near signature if visible')\n",
    "\n",
    "\n",
    "class AcademicNoticeSchema(BaseModel):\n",
    "    issuing_authority: Optional[str]   = None\n",
    "    reference_number:  Optional[str]   = None\n",
    "    date_issued:       Optional[str]   = None\n",
    "    subject_line:      Optional[str]   = None\n",
    "    target_audience:   Optional[List[str]] = None\n",
    "    main_body_content: Optional[str]   = None\n",
    "    signatories:       Optional[List[SignatoryEntity]] = None\n",
    "    distribution_list: Optional[List[str]] = None\n",
    "    document_type:     Optional[str]   = None\n",
    "    extra_fields:      Optional[str]   = None\n",
    "\n",
    "\n",
    "print('✅ Pydantic schema defined.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-vlm-extraction",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── 2.3  VLM Extraction Module ───────────────────────────────────────────\n",
    "EXTRACTION_PROMPT = \"\"\"\n",
    "You are an intelligent document understanding system for academic/administrative documents.\n",
    "\n",
    "STEP 1 — Classify document type: notice | office_order | exam_schedule | email | tabular_data | unknown\n",
    "\n",
    "STEP 2 — HIGH PRIORITY fields (extract with maximum accuracy):\n",
    "  • reference_number  (labels: Ref No, पत्रांक, ज्ञापांक)\n",
    "  • date_issued       (usually in header or top corner)\n",
    "  • issuing_authority\n",
    "\n",
    "STEP 3 — main_body_content MUST contain ALL readable text from the document.\n",
    "  Preserve logical reading order. Do NOT return null unless completely empty.\n",
    "\n",
    "STEP 4 — General rules:\n",
    "  • Extract ONLY clearly present fields; missing → null\n",
    "  • Preserve Hindi and English exactly as written\n",
    "  • Tables → Markdown format, preserve structure\n",
    "  • Do NOT hallucinate or summarise\n",
    "  • extra_fields → JSON string for tables / unknown structures\n",
    "\n",
    "Return valid JSON only.\n",
    "\"\"\"\n",
    "\n",
    "\n",
    "def extract_structured_metadata(image_path: str) -> AcademicNoticeSchema:\n",
    "    \"\"\"\n",
    "    Extracts structured JSON from a scanned notice image\n",
    "    using Gemini 2.5 Flash with Pydantic structured output.\n",
    "    \"\"\"\n",
    "    try:\n",
    "        document_image = Image.open(image_path)\n",
    "    except FileNotFoundError:\n",
    "        raise ValueError(f'Image not found: {image_path}')\n",
    "\n",
    "    response = client.models.generate_content(\n",
    "        model='gemini-2.5-flash',\n",
    "        contents=[document_image, EXTRACTION_PROMPT],\n",
    "        config=types.GenerateContentConfig(\n",
    "            response_mime_type='application/json',\n",
    "            response_schema=AcademicNoticeSchema,\n",
    "            temperature=0.0\n",
    "        )\n",
    "    )\n",
    "\n",
    "    parsed = response.parsed\n",
    "    if not parsed.main_body_content:\n",
    "        parsed.main_body_content = ''\n",
    "    return parsed\n",
    "\n",
    "\n",
    "print('✅ VLM extraction module ready.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-chunking",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── 2.4  Chunking Module ─────────────────────────────────────────────────\n",
    "from langchain_text_splitters import RecursiveCharacterTextSplitter\n",
    "from langchain_core.documents import Document\n",
    "\n",
    "\n",
    "def create_intelligent_context_chunks(structured_notice: AcademicNoticeSchema) -> List[Document]:\n",
    "    \"\"\"\n",
    "    Converts a structured notice into context-enriched LangChain Documents.\n",
    "    Each chunk includes the global metadata header for retrieval context.\n",
    "    \"\"\"\n",
    "    global_metadata = {\n",
    "        'issuing_authority': structured_notice.issuing_authority,\n",
    "        'reference_number':  structured_notice.reference_number or 'UNKNOWN_REF',\n",
    "        'date_issued':       structured_notice.date_issued,\n",
    "        'subject':           structured_notice.subject_line or 'General Administrative Notice'\n",
    "    }\n",
    "\n",
    "    context_header = (\n",
    "        f\"Notice Reference: {global_metadata['reference_number']}, \"\n",
    "        f\"Date: {global_metadata['date_issued']}, \"\n",
    "        f\"Subject: {global_metadata['subject']}.\\nContent: \"\n",
    "    )\n",
    "\n",
    "    body_text = (structured_notice.main_body_content or '').strip()\n",
    "\n",
    "    text_splitter = RecursiveCharacterTextSplitter(\n",
    "        chunk_size=1500,\n",
    "        chunk_overlap=250,\n",
    "        separators=['\\n\\n', '\\n', '।', '.', ' ', '']\n",
    "    )\n",
    "\n",
    "    raw_chunks = text_splitter.split_text(body_text)\n",
    "\n",
    "    return [\n",
    "        Document(\n",
    "            page_content=context_header + chunk,\n",
    "            metadata=global_metadata\n",
    "        )\n",
    "        for chunk in raw_chunks\n",
    "    ]\n",
    "\n",
    "\n",
    "print('✅ Chunking module ready.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-embeddings",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── 2.5  Multilingual Embedding Model (BAAI/bge-m3) ─────────────────────\n",
    "# NOTE: First load takes ~2-3 minutes to download the model weights.\n",
    "from langchain_huggingface import HuggingFaceEmbeddings\n",
    "\n",
    "\n",
    "def initialize_embedding_model() -> HuggingFaceEmbeddings:\n",
    "    \"\"\"\n",
    "    Loads BAAI/bge-m3 — a superior multilingual model with 8192-token context.\n",
    "    Ideal for Hindi-English code-mixed academic documents.\n",
    "    \"\"\"\n",
    "    return HuggingFaceEmbeddings(\n",
    "        model_name='BAAI/bge-m3',\n",
    "        model_kwargs={'device': 'cpu'},\n",
    "        encode_kwargs={'normalize_embeddings': True}   # Required for cosine similarity\n",
    "    )\n",
    "\n",
    "\n",
    "print('⏳ Loading BAAI/bge-m3 embedding model (first run ~2-3 min)...')\n",
    "embedding_model = initialize_embedding_model()\n",
    "print('✅ Embedding model loaded.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-vectorstore",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── 2.6  Hybrid Retrieval System (ChromaDB + BM25) ──────────────────────\n",
    "from langchain.vectorstores import Chroma\n",
    "from langchain.retrievers import BM25Retriever, EnsembleRetriever\n",
    "\n",
    "\n",
    "def load_processed_log():\n",
    "    if os.path.exists(LOG_PATH):\n",
    "        with open(LOG_PATH, 'r') as f:\n",
    "            return json.load(f)\n",
    "    return []\n",
    "\n",
    "\n",
    "def save_processed_log(log):\n",
    "    with open(LOG_PATH, 'w') as f:\n",
    "        json.dump(log, f)\n",
    "\n",
    "\n",
    "def load_bm25_docs():\n",
    "    if os.path.exists(BM25_DOCS_PATH):\n",
    "        with open(BM25_DOCS_PATH, 'r') as f:\n",
    "            return json.load(f)\n",
    "    return []\n",
    "\n",
    "\n",
    "def save_bm25_docs(docs):\n",
    "    with open(BM25_DOCS_PATH, 'w') as f:\n",
    "        json.dump(docs, f, indent=2)\n",
    "\n",
    "\n",
    "def build_hybrid_retriever(new_documents: List[Document], embeddings: HuggingFaceEmbeddings) -> EnsembleRetriever:\n",
    "    \"\"\"\n",
    "    Builds a hybrid EnsembleRetriever combining:\n",
    "      - Semantic search (ChromaDB + bge-m3)  weight=0.6\n",
    "      - Keyword  search (BM25 over all docs)  weight=0.4\n",
    "    \"\"\"\n",
    "    # ── ChromaDB: persistent vector store ─────────────\n",
    "    vector_store = Chroma(\n",
    "        persist_directory=CHROMA_PATH,\n",
    "        embedding_function=embeddings\n",
    "    )\n",
    "    if new_documents:\n",
    "        vector_store.add_documents(new_documents)\n",
    "        vector_store.persist()\n",
    "\n",
    "    semantic_retriever = vector_store.as_retriever(search_kwargs={'k': 4})\n",
    "\n",
    "    # ── BM25: keyword retriever over ALL documents ─────\n",
    "    existing_docs = load_bm25_docs()\n",
    "    new_doc_dicts = [\n",
    "        {'content': d.page_content, 'metadata': d.metadata}\n",
    "        for d in new_documents\n",
    "    ]\n",
    "    all_docs = existing_docs + new_doc_dicts\n",
    "    save_bm25_docs(all_docs)\n",
    "\n",
    "    retrievers = [semantic_retriever]\n",
    "    weights    = [1.0]\n",
    "\n",
    "    if all_docs:\n",
    "        bm25_retriever   = BM25Retriever.from_texts([d['content'] for d in all_docs])\n",
    "        bm25_retriever.k = 4\n",
    "        retrievers.append(bm25_retriever)\n",
    "        weights = [0.6, 0.4]\n",
    "\n",
    "    return EnsembleRetriever(retrievers=retrievers, weights=weights)\n",
    "\n",
    "\n",
    "print('✅ Hybrid retrieval module ready.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-ingest-pipeline",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── 2.7  Run Document Ingestion ──────────────────────────────────────────\n",
    "# Scans INPUT_PATH for new images, extracts text via Gemini VLM,\n",
    "# embeds chunks, and adds them to ChromaDB + BM25.\n",
    "\n",
    "import shutil\n",
    "\n",
    "processed_files = load_processed_log()\n",
    "all_files       = os.listdir(INPUT_PATH)\n",
    "new_files       = [\n",
    "    f for f in all_files\n",
    "    if f not in processed_files and f.lower().endswith(('.jpg', '.jpeg', '.png'))\n",
    "]\n",
    "\n",
    "print(f'🔍 Found {len(new_files)} new file(s) to process: {new_files}')\n",
    "\n",
    "documents_to_add = []\n",
    "\n",
    "for i, filename in enumerate(new_files, 1):\n",
    "    image_path = os.path.join(INPUT_PATH, filename)\n",
    "    print(f'  [{i}/{len(new_files)}] Processing: {filename}')\n",
    "\n",
    "    try:\n",
    "        structured_notice = extract_structured_metadata(image_path)\n",
    "        chunks = create_intelligent_context_chunks(structured_notice)\n",
    "        documents_to_add.extend(chunks)\n",
    "\n",
    "        # Move to processed folder\n",
    "        shutil.move(image_path, os.path.join(PROCESSED_PATH, filename))\n",
    "        processed_files.append(filename)\n",
    "        print(f'     ✅ Extracted {len(chunks)} chunk(s), moved to processed/')\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f'     ❌ Failed: {e}')\n",
    "\n",
    "save_processed_log(processed_files)\n",
    "\n",
    "# Build / update the hybrid retriever\n",
    "print('\\n⏳ Building hybrid retriever...')\n",
    "hybrid_retriever = build_hybrid_retriever(documents_to_add, embedding_model)\n",
    "\n",
    "total_bm25 = len(load_bm25_docs())\n",
    "print(f'\\n✅ Ingestion complete.')\n",
    "print(f'   New chunks added  : {len(documents_to_add)}')\n",
    "print(f'   Total BM25 chunks : {total_bm25}')\n",
    "print(f'   Hybrid retriever  : ready')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section3-header",
   "metadata": {},
   "source": [
    "---\n",
    "## 🚀 SECTION 3 — Flask API Server\n",
    "\n",
    "This starts the RAG backend that `chatbot.js` calls.\n",
    "\n",
    "**Endpoints:**\n",
    "| Method | Path | Description |\n",
    "|--------|------|-------------|\n",
    "| `POST` | `/api/rag/query` | Query the RAG system, returns AI answer + sources |\n",
    "| `GET` | `/api/rag/stats` | Returns knowledge base statistics |\n",
    "| `GET` | `/api/health` | Health check |\n",
    "\n",
    "After running the cell below, **copy the ngrok URL** and paste it into `chatbot.js`:\n",
    "```javascript\n",
    "RAG_BACKEND_URL: 'https://xxxx-xx-xx-xxx-xx.ngrok-free.app',\n",
    "```"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-rag-query-fn",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── 3.1  RAG Query Function ──────────────────────────────────────────────\n",
    "\n",
    "GPA_SYSTEM_PROMPT = \"\"\"\n",
    "You are \"GPA Assistant\" — an intelligent administrative chatbot for\n",
    "Government Polytechnic Adityapur (GPA), Jamshedpur, Jharkhand, India.\n",
    "\n",
    "RULES:\n",
    "• Answer ONLY using the provided CONTEXT when it is relevant.\n",
    "• If the context does not contain the answer, say:\n",
    "  \"Information regarding this query is not available in our knowledge base.\"\n",
    "• Keep answers concise and factual.\n",
    "• Preserve Hindi text as-is.\n",
    "• Do NOT hallucinate dates, numbers, or names.\n",
    "\"\"\"\n",
    "\n",
    "\n",
    "def generate_rag_answer(user_query: str, retriever: EnsembleRetriever) -> dict:\n",
    "    \"\"\"\n",
    "    Full RAG pipeline:\n",
    "    1. Retrieve top-k relevant chunks (hybrid: semantic + BM25)\n",
    "    2. Build augmented prompt\n",
    "    3. Generate answer with Gemini 2.5 Flash\n",
    "    Returns: { answer, sources, chunk_count }\n",
    "    \"\"\"\n",
    "    retrieved_docs = retriever.invoke(user_query)\n",
    "\n",
    "    if not retrieved_docs:\n",
    "        return {\n",
    "            'answer': 'Information regarding this query is not available in our knowledge base.',\n",
    "            'sources': [],\n",
    "            'chunk_count': 0\n",
    "        }\n",
    "\n",
    "    context_blocks = []\n",
    "    sources = []\n",
    "    for i, doc in enumerate(retrieved_docs, 1):\n",
    "        context_blocks.append(f'[Source {i}]: {doc.page_content}')\n",
    "        meta = doc.metadata\n",
    "        sources.append({\n",
    "            'index':     i,\n",
    "            'reference': meta.get('reference_number', 'N/A'),\n",
    "            'date':      meta.get('date_issued', 'N/A'),\n",
    "            'subject':   meta.get('subject', 'N/A'),\n",
    "            'authority': meta.get('issuing_authority', 'N/A')\n",
    "        })\n",
    "\n",
    "    aggregated_context = '\\n\\n---\\n\\n'.join(context_blocks)\n",
    "\n",
    "    prompt = f\"\"\"{GPA_SYSTEM_PROMPT}\n",
    "\n",
    "CONTEXT FROM KNOWLEDGE BASE:\n",
    "{aggregated_context}\n",
    "\n",
    "USER QUERY: {user_query}\n",
    "\n",
    "Answer the query based on the context above:\"\"\"\n",
    "\n",
    "    response = client.models.generate_content(\n",
    "        model='gemini-2.5-flash',\n",
    "        contents=prompt,\n",
    "        config=types.GenerateContentConfig(temperature=0.2)\n",
    "    )\n",
    "\n",
    "    return {\n",
    "        'answer':      response.text,\n",
    "        'sources':     sources,\n",
    "        'chunk_count': len(retrieved_docs)\n",
    "    }\n",
    "\n",
    "\n",
    "# Quick sanity-check\n",
    "print('✅ RAG query function ready.')\n",
    "print('   Testing with a sample query...')\n",
    "test = generate_rag_answer('What are the latest notices?', hybrid_retriever)\n",
    "print(f'   Answer preview: {test[\"answer\"][:120]}...')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-flask-server",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── 3.2  Flask API Server + ngrok tunnel ────────────────────────────────\n",
    "import threading\n",
    "from flask import Flask, request, jsonify\n",
    "from flask_cors import CORS\n",
    "from pyngrok import ngrok, conf\n",
    "\n",
    "app = Flask(__name__)\n",
    "CORS(app, resources={r'/api/*': {'origins': '*'}})   # Allow all origins (chatbot.js)\n",
    "\n",
    "# ─── Global state (set once retriever is built) ───\n",
    "_retriever = hybrid_retriever  # Set from Section 2\n",
    "\n",
    "\n",
    "@app.route('/api/health', methods=['GET'])\n",
    "def health_check():\n",
    "    return jsonify({'status': 'ok', 'service': 'GPA RAG Backend', 'version': '2.0'})\n",
    "\n",
    "\n",
    "@app.route('/api/rag/stats', methods=['GET'])\n",
    "def rag_stats():\n",
    "    \"\"\"Returns knowledge base statistics.\"\"\"\n",
    "    try:\n",
    "        bm25_docs = load_bm25_docs()\n",
    "        processed = load_processed_log()\n",
    "        return jsonify({\n",
    "            'total_chunks':   len(bm25_docs),\n",
    "            'total_documents': len(processed),\n",
    "            'status':         'ready'\n",
    "        })\n",
    "    except Exception as e:\n",
    "        return jsonify({'error': str(e)}), 500\n",
    "\n",
    "\n",
    "@app.route('/api/rag/query', methods=['POST'])\n",
    "def rag_query():\n",
    "    \"\"\"\n",
    "    Main endpoint called by chatbot.js.\n",
    "\n",
    "    Request JSON:  { \"query\": \"<user question>\" }\n",
    "    Response JSON: { \"answer\": \"...\", \"sources\": [...], \"chunk_count\": N }\n",
    "    \"\"\"\n",
    "    if _retriever is None:\n",
    "        return jsonify({'error': 'RAG system not initialised. Run Section 2 first.'}), 503\n",
    "\n",
    "    data = request.get_json(silent=True)\n",
    "    if not data or 'query' not in data:\n",
    "        return jsonify({'error': 'Missing \"query\" field in request body.'}), 400\n",
    "\n",
    "    user_query = str(data['query']).strip()\n",
    "    if not user_query:\n",
    "        return jsonify({'error': 'Query cannot be empty.'}), 400\n",
    "\n",
    "    try:\n",
    "        result = generate_rag_answer(user_query, _retriever)\n",
    "        return jsonify(result)\n",
    "    except Exception as e:\n",
    "        return jsonify({'error': f'RAG query failed: {str(e)}'}), 500\n",
    "\n",
    "\n",
    "# ─── Start ngrok + Flask in background ───────────────────────────────────\n",
    "conf.get_default().auth_token = NGROK_AUTH_TOKEN\n",
    "\n",
    "# Kill any existing ngrok tunnels\n",
    "ngrok.kill()\n",
    "\n",
    "# Open tunnel on port 5000\n",
    "public_url = ngrok.connect(5000).public_url\n",
    "\n",
    "print('=' * 60)\n",
    "print('🌐  GPA RAG Backend is LIVE!')\n",
    "print('=' * 60)\n",
    "print(f'   Public URL : {public_url}')\n",
    "print()\n",
    "print('📋  Copy this URL into chatbot.js:')\n",
    "print(f'    RAG_BACKEND_URL: \\'{public_url}\\',')\n",
    "print()\n",
    "print('   Endpoints:')\n",
    "print(f'   GET  {public_url}/api/health')\n",
    "print(f'   GET  {public_url}/api/rag/stats')\n",
    "print(f'   POST {public_url}/api/rag/query   {{\"query\": \"...\"}}')\n",
    "print('=' * 60)\n",
    "\n",
    "# Run Flask in a daemon thread so this cell stays interactive\n",
    "def run_server():\n",
    "    app.run(port=5000, debug=False, use_reloader=False)\n",
    "\n",
    "server_thread = threading.Thread(target=run_server, daemon=True)\n",
    "server_thread.start()\n",
    "\n",
    "print('\\n⚡ Server running. Keep this notebook open while using the chatbot.')"
   ]
  },
